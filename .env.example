# Copy to .env and fill in. Never commit the real .env.

# Anthropic API key for the agent planner.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Planner model. Default is Sonnet for cost/latency on long tool loops.
# Use claude-opus-4-7 for the hardest cases.
SIFT_SENTINEL_MODEL=claude-sonnet-4-6

# How to reach the Protocol SIFT MCP server.
# stdio: launch the server as a subprocess (default on a SIFT Workstation).
# Set to the command Protocol SIFT installs, e.g. "protocol-sift-mcp".
SIFT_SENTINEL_MCP_COMMAND=protocol-sift-mcp

# Max plan-act-validate iterations before the run is force-stopped.
SIFT_SENTINEL_MAX_ITERATIONS=40
